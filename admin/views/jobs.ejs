<!doctype html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Job Applications</title>
  <link rel="stylesheet" href="/assets/admin.css">
</head>
<body>
  <div class="admin-shell">
    <header class="admin-header">
      <div>
        <span class="eyebrow">TSPL Admin</span>
        <h1>Job applications</h1>
        <p>Review applicants, preview files, and download CVs without leaving the dashboard.</p>
      </div>
      <div class="header-actions">
        <% if (user && user.role === 'super') { %>
          <a class="ghost-btn" href="/admin/add-admin">Add Admin</a>
        <% } %>
        <a class="ghost-btn" href="/admin/logout">Logout</a>
      </div>
    </header>

    <nav class="tab-bar">
      <a href="?section=contacts">Contacts</a>
      <a href="?section=services">Services</a>
      <a href="?section=jobs" class="active">Jobs</a>
    </nav>

    <% if (items && items.length > 0) { %>
      <section class="card table-card">
        <div class="card-head">
          <h2>Latest applicants</h2>
          <span class="badge"><%= items.length %> records</span>
        </div>
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>Name</th>
                <th>Email</th>
                <th>Phone</th>
                <th>Job Title</th>
                <th>Company</th>
                <th>Files</th>
                <th>Submitted</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% items.forEach(item => { %>
                <tr>
                  <td><%= item.name || 'N/A' %></td>
                  <td><%= item.email || 'N/A' %></td>
                  <td><%= item.phone || 'N/A' %></td>
                  <td>
                    <% if (item.metadata && item.metadata.jobTitle) { %>
                      <%= item.metadata.jobTitle %>
                    <% } else { %>
                      N/A
                    <% } %>
                  </td>
                  <td>
                    <% if (item.metadata && item.metadata.company) { %>
                      <%= item.metadata.company %>
                    <% } else { %>
                      N/A
                    <% } %>
                  </td>
                  <td>
                    <% if (item.cv) { %>
                      <span class="badge success">CV ✓</span>
                    <% } %>
                    <% if (item.pdf) { %>
                      <span class="badge success">PDF ✓</span>
                    <% } %>
                  </td>
                  <td><%= new Date(item.createdAt).toLocaleString() %></td>
                  <td>
                    <div class="actions">
                      <% if (item.cv) { %>
                        <button class="btn primary" onclick="previewFile('<%= item.cv %>', 'cv')">View CV</button>
                      <% } %>
                      <% if (item.pdf) { %>
                        <button class="btn primary" onclick="previewFile('<%= item.pdf %>', 'pdf')">View PDF</button>
                      <% } %>
                      <% if (item.cv) { %>
                        <a class="btn secondary" href="<%= item.cv %>" download>Download CV</a>
                      <% } %>
                    </div>
                  </td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      </section>
    <% } else { %>
      <section class="empty-state card">
        <h2>No job applications yet</h2>
        <p>CVs and application files will show up here as soon as candidates apply.</p>
      </section>
    <% } %>
  </div>

  <!-- File Preview Modal -->
  <div id="fileModal" class="modal">
    <div class="modal-content">
      <div class="modal-header">
        <h2 id="fileTitle">File Preview</h2>
        <button class="modal-close" onclick="closeModal()">&times;</button>
      </div>
      <div id="fileContainer"></div>
    </div>
  </div>

  <script>
    function previewFile(filename, type) {
      const fileModal = document.getElementById('fileModal');
      const fileContainer = document.getElementById('fileContainer');
      const fileTitle = document.getElementById('fileTitle');
      
      fileTitle.textContent = `Preview: ${filename}`;
      fileContainer.innerHTML = '';
      
      const fileUrl = filename; // DB stores the full URL/path like /public/uploads/cvs/...
      
      if (filename.toLowerCase().endsWith('.pdf')) {
        fileContainer.innerHTML = `<iframe class="file-embed" src="${fileUrl}"></iframe>`;
      } else if (['.jpg', '.jpeg', '.png', '.gif'].some(ext => filename.toLowerCase().endsWith(ext))) {
        fileContainer.innerHTML = `<img class="file-embed" src="${fileUrl}" alt="Preview" style="object-fit: contain;" />`;
      } else {
        fileContainer.innerHTML = `<p>File type not supported for preview. <a href="${fileUrl}" download>Download instead</a></p>`;
      }
      
      fileModal.classList.add('show');
    }

    function closeModal() {
      const fileModal = document.getElementById('fileModal');
      fileModal.classList.remove('show');
    }

    // Close modal when clicking outside
    document.getElementById('fileModal').addEventListener('click', function(e) {
      if (e.target === this) {
        closeModal();
      }
    });
  </script>
</body>
</html>
