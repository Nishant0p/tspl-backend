<!doctype html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Service Enquiries</title>
  <link rel="stylesheet" href="/assets/admin.css">
</head>
<body>
  <div class="admin-shell">
    <header class="admin-header">
      <div>
        <span class="eyebrow">TSPL Admin</span>
        <h1>Service enquiries</h1>
        <p>Track service requests and quotes from the same control panel.</p>
      </div>
      <div class="header-actions">
        <% if (user && user.role === 'super') { %>
          <a class="ghost-btn" href="/admin/add-admin">Add Admin</a>
        <% } %>
        <a class="ghost-btn" href="/admin/logout">Logout</a>
      </div>
    </header>

    <nav class="tab-bar">
      <a href="?section=contacts">Contacts</a>
      <a href="?section=services" class="active">Services</a>
      <a href="?section=jobs">Jobs</a>
    </nav>

    <% if (items && items.length > 0) { %>
      <section class="card table-card">
        <div class="card-head">
          <h2>Latest service leads</h2>
          <span class="badge"><%= items.length %> records</span>
        </div>
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>Name</th>
                <th>Email</th>
                <th>Phone</th>
                <th>Service</th>
                <th>Company</th>
                <th>City</th>
                <th>Message</th>
                <th>Submitted</th>
                <% if (user && user.role === 'super') { %>
                  <th>Actions</th>
                <% } %>
              </tr>
            </thead>
            <tbody>
              <% items.forEach(item => { %>
                <tr>
                  <td><%= item.name || 'N/A' %></td>
                  <td><%= item.email || 'N/A' %></td>
                  <td><%= item.phone || 'N/A' %></td>
                  <td>
                    <% if (item.metadata && item.metadata.service) { %>
                      <%= item.metadata.service %>
                    <% } else { %>
                      N/A
                    <% } %>
                  </td>
                  <td>
                    <% if (item.metadata && item.metadata.company) { %>
                      <%= item.metadata.company %>
                    <% } else { %>
                      N/A
                    <% } %>
                  </td>
                  <td>
                    <% if (item.metadata && item.metadata.city) { %>
                      <%= item.metadata.city %>
                    <% } else { %>
                      N/A
                    <% } %>
                  </td>
                  <td class="truncate"><%= item.message || 'No message' %></td>
                  <td><%= new Date(item.createdAt).toLocaleString() %></td>
                  <% if (user && user.role === 'super') { %>
                    <td>
                      <form action="/admin/delete/service/<%= item.id %>" method="POST" onsubmit="return confirm('Delete this service enquiry?');">
                        <button type="submit" class="btn secondary" style="color: #dc2626; padding: 8px 12px; font-size: 14px; border-color: #fecaca; background: #fef2f2;" title="Delete">&#10005;</button>
                      </form>
                    </td>
                  <% } %>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      </section>
    <% } else { %>
      <section class="empty-state card">
        <h2>No service enquiries yet</h2>
        <p>New requests will appear here once customers submit the form.</p>
      </section>
    <% } %>
  </div>
</body>
</html>
