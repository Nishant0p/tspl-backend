<!doctype html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Admin Login</title>
  <link rel="stylesheet" href="/assets/admin.css">
</head>
<body>
  <div class="auth-shell">
    <div class="auth-panel">
      <div class="auth-copy">
        <span class="eyebrow">TSPL Admin</span>
        <h1>Welcome back.</h1>
        <p>Sign in to review contacts, service leads, and job applications in one place.</p>
      </div>
      <form class="auth-form" action="/admin/login" method="post">
        <input type="hidden" name="browserLogin" value="1" />
        <label>
          <span>Email</span>
          <input name="email" type="email" autocomplete="username" placeholder="admin@company.com" required />
        </label>
        <label>
          <span>Password</span>
          <input name="password" type="password" autocomplete="current-password" placeholder="Enter your password" required />
        </label>
        <% if (error) { %>
          <p class="form-message error" aria-live="polite">Invalid email or password.</p>
        <% } else { %>
          <p class="form-message" aria-live="polite">Use your admin credentials to sign in.</p>
        <% } %>
        <button type="submit" class="primary-btn">Sign in</button>
        <p class="auth-note">Your browser session is secured with an httpOnly token cookie.</p>
      </form>
    </div>
  </div>
</body>
</html>
