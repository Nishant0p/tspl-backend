<!doctype html>
<html>
<head><meta charset="utf-8"><title>List</title></head>
<body>
  <h1><%= title %></h1>
  <table border="1">
    <thead><tr><% Object.keys(items[0] || {}).forEach(h=>{ %><th><%= h %></th><% }) %></tr></thead>
    <tbody>
      <% items.forEach(it=>{ %>
        <tr>
          <% Object.keys(it).forEach(k=>{ %>
            <td><%= it[k] %></td>
          <% }) %>
        </tr>
      <% }) %>
    </tbody>
  </table>
</body>
</html>
