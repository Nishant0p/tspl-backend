<!doctype html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Add Admin</title>
  <link rel="stylesheet" href="/assets/admin.css">
</head>
<body>
  <div class="admin-shell">
    <header class="admin-header">
      <div>
        <span class="eyebrow">TSPL Admin</span>
        <h1>Add Admin</h1>
        <p>Create a new admin account (super users only).</p>
      </div>
      <div class="header-actions">
        <a class="ghost-btn" href="/admin/dashboard">Dashboard</a>
        <a class="ghost-btn" href="/admin/logout">Logout</a>
      </div>
    </header>

    <section class="card" style="max-width:720px; margin-top:20px;">
      <form id="addAdminForm" class="auth-form">
        <label>
          <span>Email</span>
          <input name="email" type="email" placeholder="newadmin@example.com" required />
        </label>
        <label>
          <span>Password</span>
          <input name="password" type="password" placeholder="Choose a strong password" required />
        </label>
        <p id="result" class="form-message" aria-live="polite"></p>
        <button type="submit" class="primary-btn">Create Admin</button>
      </form>
    </section>

    <% if (admins && admins.length > 0) { %>
    <section class="card table-card" style="margin-top:20px;">
      <div class="card-head">
        <h2>Existing Admins</h2>
        <span class="badge"><%= admins.length %> records</span>
      </div>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>ID</th>
              <th>Email</th>
              <th>Role</th>
              <th>Created At</th>
            </tr>
          </thead>
          <tbody>
            <% admins.forEach(admin => { %>
              <tr>
                <td><%= admin.id %></td>
                <td><strong><%= admin.email %></strong></td>
                <td><span class="badge"><%= admin.role %></span></td>
                <td><%= new Date(admin.createdAt).toLocaleString() %></td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    </section>
    <% } %>
  </div>

  <script>
    const form = document.getElementById('addAdminForm');
    const result = document.getElementById('result');

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      result.textContent = 'Creating...';
      try {
        const res = await fetch('/api/auth/admins', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'include',
          body: JSON.stringify({ email: form.email.value, password: form.password.value })
        });
        const body = await res.json();
        if (!res.ok) throw new Error(body.error || 'Failed');
        result.textContent = 'Admin created: ' + body.email;
        setTimeout(()=> location.href = '/admin/dashboard', 1200);
      } catch (err) {
        result.textContent = err.message || 'Create failed';
        result.className = 'form-message error';
      }
    });
  </script>
</body>
</html>
