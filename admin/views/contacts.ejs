<!doctype html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Contact Form Submissions</title>
  <link rel="stylesheet" href="/assets/admin.css">
</head>
<body>
  <div class="admin-shell">
    <header class="admin-header">
      <div>
        <span class="eyebrow">TSPL Admin</span>
        <h1>Contact submissions</h1>
        <p>Monitor incoming contact requests and respond faster from one dashboard.</p>
      </div>
      <div class="header-actions">
        <a class="ghost-btn" href="/admin/logout">Logout</a>
      </div>
    </header>

    <nav class="tab-bar">
      <a href="?section=contacts" class="active">Contacts</a>
      <a href="?section=services">Services</a>
      <a href="?section=jobs">Jobs</a>
    </nav>

    <% if (items && items.length > 0) { %>
      <section class="card table-card">
        <div class="card-head">
          <h2>Latest contact leads</h2>
          <span class="badge"><%= items.length %> records</span>
        </div>
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>Name</th>
                <th>Email</th>
                <th>Phone</th>
                <th>Service</th>
                <th>Message</th>
                <th>Submitted</th>
              </tr>
            </thead>
            <tbody>
              <% items.forEach(item => { %>
                <tr>
                  <td><%= item.name || 'N/A' %></td>
                  <td><%= item.email || 'N/A' %></td>
                  <td><%= item.phone || 'N/A' %></td>
                  <td>
                    <% if (item.metadata && item.metadata.service) { %>
                      <%= item.metadata.service %>
                    <% } else { %>
                      General Inquiry
                    <% } %>
                  </td>
                  <td class="truncate"><%= item.message || 'No message' %></td>
                  <td><%= new Date(item.createdAt).toLocaleString() %></td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      </section>
    <% } else { %>
      <section class="empty-state card">
        <h2>No contact submissions yet</h2>
        <p>Once visitors start sending messages, they will appear here automatically.</p>
      </section>
    <% } %>
  </div>
</body>
</html>
